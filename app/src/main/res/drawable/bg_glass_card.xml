<?xml version="1.0" encoding="utf-8"?>
<!-- Glassmorphic card background drawable.
     True blur requires API 31+ RenderEffect applied in Java.
     This drawable provides the tinted color layer beneath the blur.
     Corner radius: 24dp (1.5rem equivalent — "XL" in design system).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/glass_surface_40"/>
    <stroke
        android:width="0.5dp"
        android:color="@color/outline_variant"/>
    <corners android:radius="24dp"/>
</shape>

<?xml version="1.0" encoding="utf-8"?>
<!--
    Create Group Dialog Layout
    Simple dialog with group name and emoji icon input.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Group Name Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Group name (e.g. Goa Trip)"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/outline_variant"
        app:boxBackgroundColor="@color/surface_container_high"
        app:hintTextColor="@color/on_surface_variant">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_group_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapWords"
            android:textColor="@color/on_surface" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Group Icon Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Icon emoji (optional, e.g. 🏠)"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/outline_variant"
        app:boxBackgroundColor="@color/surface_container_high"
        app:hintTextColor="@color/on_surface_variant">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_group_icon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/on_surface"
            android:maxLength="2" />

    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>

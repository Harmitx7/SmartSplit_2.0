<?xml version="1.0" encoding="utf-8"?>
<!--
    Add Member Dialog Layout. Single text field.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Member name"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/outline_variant"
        app:boxBackgroundColor="@color/surface_container_high"
        app:hintTextColor="@color/on_surface_variant">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_member_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName|textCapWords"
            android:textColor="@color/on_surface" />

    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>

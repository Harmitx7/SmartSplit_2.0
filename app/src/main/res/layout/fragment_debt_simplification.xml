<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_debt_simplification.xml
    Ethereal Ledger — Simplified Payments Screen
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Glow orb top-left -->
    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="-80dp"
        android:layout_marginStart="-80dp"
        android:alpha="0.12"
        android:background="@drawable/bg_glow_orb_primary" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Top bar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp">

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_glass_card"
                    android:contentDescription="@string/cd_back_button"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/on_surface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/simplified_transactions"
                    android:textColor="@color/on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- ── EMPTY / ALL CLEAR STATE ─────────────────────── -->
            <LinearLayout
                android:id="@+id/empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="gone">

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lottie_success"
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:contentDescription="@string/cd_lottie_success"
                    app:lottie_loop="false"
                    app:lottie_rawRes="@raw/lottie_success" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/debt_all_clear"
                    android:textColor="@color/tertiary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:gravity="center"
                    android:text="@string/all_settled_subtitle"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ── MAIN CONTENT ──────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/content_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                tools:visibility="visible">

                <!-- Reduction Hero Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/glass_surface_40"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:letterSpacing="0.12"
                            android:text="@string/simplification_subtitle"
                            android:textAllCaps="true"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_original_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/space_grotesk"
                                android:text="—"
                                android:textColor="@color/error"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="Original: 6 transactions" />

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginHorizontal="12dp"
                                android:src="@drawable/ic_arrow_right"
                                app:tint="@color/on_surface_variant" />

                            <TextView
                                android:id="@+id/tv_simplified_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/space_grotesk"
                                android:text="—"
                                android:textColor="@color/tertiary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="Simplified to: 2 transactions" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Transactions List -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/simplified_transactions"
                    android:textColor="@color/on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_transactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_simplified_transaction" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

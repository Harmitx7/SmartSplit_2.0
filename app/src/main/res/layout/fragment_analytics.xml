<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_analytics.xml
    Ethereal Ledger — Analytics Screen
    Design: Glassmorphic dark surface, PieChart + stat cards
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    tools:context=".ui.analytics.AnalyticsFragment">

    <!-- Atmospheric Glow Blobs (decorative) -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="-80dp"
        android:layout_marginStart="-80dp"
        android:background="@drawable/bg_glow_orb_primary"
        android:alpha="0.15" />

    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="-60dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_glow_orb_secondary"
        android:alpha="0.10" />

    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── Top Bar ─────────────────────────────────────────── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_glass_card"
                    android:contentDescription="@string/cd_back_button"
                    android:padding="8dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/on_surface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:fontFamily="@font/space_grotesk"
                    android:text="@string/analytics"
                    android:textColor="@color/on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- ── Section Label ──────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/space_grotesk"
                android:letterSpacing="0.15"
                android:text="@string/spending_breakdown"
                android:textAllCaps="true"
                android:textColor="@color/secondary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/space_grotesk"
                android:text="@string/analytics"
                android:textColor="@color/on_surface"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- ── EMPTY STATE ─────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/empty_state"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="gone">

                <com.airbnb.lottie.LottieAnimationView
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:contentDescription="@string/cd_lottie_empty"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/lottie_empty" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:gravity="center"
                    android:text="@string/no_expenses_analytics"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ── MAIN CONTENT (Charts + Cards) ─────────────────── -->
            <LinearLayout
                android:id="@+id/content_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                tools:visibility="visible">

                <!-- Pie Chart inside glass card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardBackgroundColor="@color/glass_surface_40"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pie_chart"
                        android:layout_width="match_parent"
                        android:layout_height="280dp"
                        android:layout_margin="8dp" />

                </androidx.cardview.widget.CardView>

                <!-- ── Stat Cards Row ──────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Total Spend Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_total_spend"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/glass_surface_40"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_wallet"
                                    app:tint="@color/tertiary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:fontFamily="@font/plus_jakarta_sans"
                                    android:letterSpacing="0.12"
                                    android:text="@string/total_spend"
                                    android:textAllCaps="true"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="9sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_total_spend"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="@font/space_grotesk"
                                android:text="$0.00"
                                android:textColor="@color/tertiary"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:text="$482.50" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Top Category Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/glass_surface_40"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_insights"
                                    app:tint="@color/secondary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:fontFamily="@font/plus_jakarta_sans"
                                    android:letterSpacing="0.12"
                                    android:text="@string/top_spender"
                                    android:textAllCaps="true"
                                    android:textColor="@color/on_surface_variant"
                                    android:textSize="9sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_top_category"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="@font/space_grotesk"
                                android:text="—"
                                android:textColor="@color/secondary"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:text="Food" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

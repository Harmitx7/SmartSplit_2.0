<?xml version="1.0" encoding="utf-8"?>
<!--
    Space Grotesk — Google Fonts downloadable font declaration.
    Used for headlines, numbers, and display text (Ethereal Ledger design).
    Doc: https://developer.android.com/guide/topics/ui/look-and-feel/downloadable-fonts
-->
<font-family xmlns:app="http://schemas.android.com/apk/res-auto"
    app:fontProviderAuthority="com.google.android.gms.fonts"
    app:fontProviderPackage="com.google.android.gms"
    app:fontProviderQuery="Space Grotesk"
    app:fontProviderCerts="@array/com_google_android_gms_fonts_certs">
</font-family>
